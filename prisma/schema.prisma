// Everroot — the Living Legacy Forest
// The Forest is the source of truth. Every object in the system is a node in a
// graph. The 3D Forest visualization is generated directly from this graph data,
// never from hardcoded UI structures.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Identity
// ---------------------------------------------------------------------------

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  profile      Profile?
  nodes        ForestNode[]
  edges        ForestEdge[]
  recordings   Recording[]

  // Invites this user has sent to bring family members into the forest.
  sentInvites  Invite[]     @relation("SentInvites")
  // PERSON nodes in OTHER users' forests that point at this account (the
  // reverse side of a family link — lets us find who has linked to me).
  linkedFrom   ForestNode[] @relation("PersonLink")
  // Sealed messages this user has left for the future.
  timeCapsules TimeCapsule[] @relation("UserCapsules")

  // A guardian this user has appointed to help steward their forest.
  guardianedBy Guardian?    @relation("OwnerGuardian")
  // Forests this user stewards on behalf of others.
  guardianFor  Guardian[]   @relation("GuardianFor")
  // Present when this user's forest has been turned into a memorial.
  memorial     Memorial?    @relation("OwnerMemorial")

  @@map("users")
}

// A guardian is a linked family member appointed to help steward another
// person's forest — adding or editing memories on their behalf, and (with
// confirmation) turning the forest into a memorial. Each forest has at most one
// guardian, so ownerId is unique.
model Guardian {
  id         String   @id @default(cuid())
  ownerId    String   @unique
  guardianId String
  createdAt  DateTime @default(now())

  owner      User     @relation("OwnerGuardian", fields: [ownerId], references: [id], onDelete: Cascade)
  guardian   User     @relation("GuardianFor", fields: [guardianId], references: [id], onDelete: Cascade)

  @@index([guardianId])
  @@map("guardians")
}

// Marks a forest as a memorial. The row's mere presence flips memorial mode on;
// deleting it turns it back off. Once memorial, linked family can leave tributes
// and the tree keeps growing as a shared remembrance.
model Memorial {
  id        String   @id @default(cuid())
  ownerId   String   @unique
  // Optional short note shown on the memorial banner.
  note      String?
  createdAt DateTime @default(now())

  owner     User     @relation("OwnerMemorial", fields: [ownerId], references: [id], onDelete: Cascade)

  @@map("memorials")
}

// A message sealed until a future date — "open on your 18th birthday", "read
// this when I'm gone". It stays locked in the forest (only its title, who it's
// for, and the unlock date are visible) until unlockAt passes, then the message
// opens for the owner and their linked family.
model TimeCapsule {
  id         String   @id @default(cuid())
  userId     String
  title      String
  message    String   @db.Text
  // Free-text note of who the capsule is meant for, e.g. "For Ava".
  recipient  String?
  unlockAt   DateTime
  createdAt  DateTime @default(now())

  user       User     @relation("UserCapsules", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("time_capsules")
}

// A shareable invitation. The inviter generates a code tied to a placeholder
// PERSON in their forest; when a family member signs up with the code, their
// new tree links (both directions) to that person. No email needed — the code
// travels however the family shares it (text, print, in person).
model Invite {
  id           String    @id @default(cuid())
  code         String    @unique
  inviterId    String
  // The placeholder PERSON node in the inviter's forest this invite fills in.
  personNodeId String?
  // How the invitee relates to the inviter, e.g. "Son", "Sister".
  relationship String?
  // Suggested display name, carried from the placeholder person.
  inviteeName  String?
  claimedById  String?
  claimedAt    DateTime?
  createdAt    DateTime  @default(now())

  inviter      User      @relation("SentInvites", fields: [inviterId], references: [id], onDelete: Cascade)

  @@index([inviterId])
  @@map("invites")
}

// A user's profile is the SEED metadata — who this tree belongs to.
model Profile {
  id            String   @id @default(cuid())
  userId        String   @unique
  displayName   String
  birthYear     Int?
  familyPosition String? // e.g. "Grandfather", "Mother", "Son"
  avatarUrl     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

// ---------------------------------------------------------------------------
// The Forest Graph
// ---------------------------------------------------------------------------

// Every object in Everroot is a ForestNode. The node's kind determines how the
// Forest renderer draws it (seed, trunk, branch, leaf, flower, fruit, roots...)
// and the growth engine uses node counts + weights to compute the tree's stage.
enum NodeKind {
  SEED
  ROOT
  TRUNK
  BRANCH
  SUB_BRANCH
  LEAF
  FLOWER
  FRUIT
  MEMORY
  PHOTO
  PERSON
  RELATIONSHIP
  TIMELINE_EVENT
  MEMORY_MOMENT
}

// Life Epochs — every memory is assigned to one or more of these.
enum LifeEpoch {
  ROOTS        // 0-12
  FIRST_STEPS  // 13-22
  CROSSROADS   // 23-35
  ANCHORS      // 36-50
  STORMS       // 51-65
  HARVEST      // 66-80
  HORIZONS     // 81+
}

model ForestNode {
  id        String   @id @default(cuid())
  userId    String
  kind      NodeKind
  title     String
  summary   String?  @db.Text

  // Optional structured payload for the node (transcript, audio url, people,
  // places, emotional tags, etc.). Kept as JSON so every content type can feed
  // the same graph without schema churn during Phase 1.
  data      Json?

  epoch     LifeEpoch?
  // Legacy score contribution of this node. The tree's total score is the sum
  // of its nodes' scores; growth stage is derived from the total.
  score     Int      @default(0)

  // If this is a PERSON node that has been claimed by a real account, this
  // points at that account. Their tree becomes part of the family forest.
  linkedUserId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // The real account this PERSON node represents, if any.
  linkedUser User?   @relation("PersonLink", fields: [linkedUserId], references: [id], onDelete: SetNull)

  // Graph edges where this node is the source / target.
  edgesFrom ForestEdge[] @relation("EdgeFrom")
  edgesTo   ForestEdge[] @relation("EdgeTo")

  recordings Recording[]

  @@index([userId])
  @@index([userId, kind])
  @@index([linkedUserId])
  @@map("forest_nodes")
}

// A voice recording captured during a life interview. The audio bytes live in
// Postgres so the actual voice is preserved with the memory it grew. Served
// (owner-only) via /api/recordings/[id] for future in-leaf playback.
model Recording {
  id         String   @id @default(cuid())
  userId     String
  nodeId     String   // the memory (ForestNode) this recording belongs to
  mimeType   String   @default("audio/webm")
  durationMs Int      @default(0)
  bytes      Bytes    // raw audio blob
  transcript String?  @db.Text
  question   String?  // the interview question that prompted this answer
  createdAt  DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  node       ForestNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([nodeId])
  @@map("recordings")
}

// How nodes connect. CONTAINS builds the tree hierarchy (trunk contains branch,
// branch contains leaf). Others capture semantic links (a leaf MENTIONS a
// person, a person is FAMILY of another person, roots ANCESTOR_OF the trunk).
enum EdgeKind {
  CONTAINS      // structural parent -> child (trunk->branch->leaf)
  GREW_INTO     // seed -> trunk growth history
  MENTIONS      // memory -> person / place
  RELATED_TO    // generic memory <-> memory link
  FAMILY        // person <-> person family relationship
  ANCESTOR_OF   // root -> trunk (heritage)
  OCCURRED_IN   // memory -> timeline event / epoch
}

model ForestEdge {
  id         String   @id @default(cuid())
  userId     String
  kind       EdgeKind
  fromNodeId String
  toNodeId   String
  // e.g. FAMILY edges store "Wife" / "Grandchild"; free-form label.
  label      String?
  createdAt  DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  fromNode   ForestNode @relation("EdgeFrom", fields: [fromNodeId], references: [id], onDelete: Cascade)
  toNode     ForestNode @relation("EdgeTo", fields: [toNodeId], references: [id], onDelete: Cascade)

  @@unique([fromNodeId, toNodeId, kind])
  @@index([userId])
  @@index([fromNodeId])
  @@index([toNodeId])
  @@map("forest_edges")
}
