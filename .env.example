# --- Database (Railway Postgres) ---
# Railway provides this automatically when you add a PostgreSQL plugin.
DATABASE_URL="postgresql://user:password@host:5432/everroot"

# --- Auth.js (NextAuth v5) ---
# Generate a secret with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-string"

# Public URL of the app. On Railway set this to your deployment domain.
# Locally this can be http://localhost:3000
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"
